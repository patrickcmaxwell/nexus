# System
.DS_Store
.*.swp
*~

# Env files (global backstop — each subproject also has its own .gitignore)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Xcode user data (machine-specific, binary)
xcuserdata/
*.xcuserstate
*.xcbuilddata
DerivedData/
# Xcode build dir — caches, ModuleCache, SourcePackages checkouts
lumen/lumen-desktop/build/

# Binary document formats (use PDF or markdown for docs in repo)
*.pages
*.numbers
*.key
*.docx
*.xlsx

# Auto-generated session log (local only)
SESSION-LOG.md

# Obsidian local workspace state (per-machine UI, not source)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/cache
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/graph.json
**/.obsidian/cache

# Claude scheduled-task lock (runtime only)
.claude/scheduled_tasks.lock

# Misc
Everything.base
.vercel
