# nexus-web — environment variables
#
# Copy to .env.local and fill in. .env.local is gitignored; .env.example is checked in.
# Most defaults assume the shared Supabase project; AI/voice keys are per-user.

# --- SUPABASE ---
# Project URL + keys from Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# --- PARTYBOT (separate Supabase project, used by the Partybot cockpit in /dashboard/partybot) ---
# Service-role only — never expose to the browser. When unset, the cockpit
# renders a "not configured" state and the rest of nexus-web works normally.
PARTYBOT_SUPABASE_URL=
PARTYBOT_SUPABASE_SERVICE_ROLE_KEY=

# --- POSTGRES ---
# Pulled from Supabase → Connect → URI. Pooler URL for app, direct for migrations.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- AI & VOICE ---
ANTHROPIC_API_KEY=
XAI_API_KEY=
AI_GATEWAY_API_KEY=
ELEVENLABS_API_KEY=

# --- SECURITY ---
# Local PIN/passphrase fallback for AuthGate when face check is unavailable.
MAXWELL_PIN=
MAXWELL_PASSPHRASE=

# --- AUTH ---
# OAuth redirect for local dev; set to http://localhost:3000/auth/callback.
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# --- QSTASH (Upstash) — required for prod agent scans ---
# Get these from console.upstash.com → QStash → your queue
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
NEXT_PUBLIC_APP_URL=

# --- CRON ---
# Used to authenticate Vercel cron calls in production
CRON_SECRET=
