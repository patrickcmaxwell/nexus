# arena — environment variables
#
# Copy to .env and fill in. .env is gitignored; .env.example is checked in.

# --- SUPABASE ---
# Same Supabase project as nexus-web. Service-role key needed to read/write
# arena_connections + the shared auth session.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- ARENA AUTH ---
# Shared secret Eve uses in `Authorization: Bearer <secret>` when calling
# Arena's executor endpoints. Must match the value set on nexus-web.
ARENA_SECRET=

# --- SERVER ---
# Port Arena's dev server binds to.
PORT=3001
