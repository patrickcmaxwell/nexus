#!/usr/bin/env bash
# vera — Nexus orchestrator CLI.
#
# Brings up nexus-web + arena + ollama-check as launchd jobs so the Director's
# Mac runs Nexus as a permanent fixture, with a single command to pause for
# travel and resume on return.
#
# Part of Operation Letsgo (mission/operation-letsgo.md). See that doc for
# the design intent and persona naming (vera = admin agent surface).

set -euo pipefail

VERA_VERSION="0.1.0"

# ── Paths ─────────────────────────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PLIST_SRC="$REPO_ROOT/scripts/launchd"
LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
LOG_DIR="$HOME/Library/Logs/Nexus"
STATE_DIR="$HOME/.vera"
STATE_FILE="$STATE_DIR/state"

# Services we manage. Keep this list in sync with scripts/launchd/*.plist.
SERVICES=(web arena ollama-check)

# ── Output helpers ────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  C_RESET=$'\033[0m'
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_CYAN=$'\033[36m'
else
  C_RESET= C_DIM= C_BOLD= C_RED= C_GREEN= C_YELLOW= C_BLUE= C_CYAN=
fi

say()  { printf '%s\n' "$*"; }
info() { printf '%s%s%s\n' "$C_CYAN" "$*" "$C_RESET"; }
ok()   { printf '%s✓%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf '%s!%s %s\n' "$C_YELLOW" "$C_RESET" "$*"; }
err()  { printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }

# ── launchd helpers ───────────────────────────────────────────────────────────
gui_target() { echo "gui/$(id -u)"; }
label_for() { echo "com.nexus.$1"; }
plist_src_for() { echo "$PLIST_SRC/com.nexus.$1.plist"; }
plist_installed_for() { echo "$LAUNCH_AGENTS/com.nexus.$1.plist"; }

is_loaded() {
  local label="$1"
  launchctl print "$(gui_target)/$label" >/dev/null 2>&1
}

bootstrap_job() {
  local svc="$1"
  local label installed
  label="$(label_for "$svc")"
  installed="$(plist_installed_for "$svc")"

  if [ ! -f "$installed" ]; then
    err "$label not installed (run: vera install)"
    return 1
  fi

  if is_loaded "$label"; then
    say "  ${C_DIM}$label already loaded${C_RESET}"
    return 0
  fi

  if launchctl bootstrap "$(gui_target)" "$installed" 2>/dev/null; then
    ok "$label bootstrapped"
  else
    err "$label failed to bootstrap (check: vera logs $svc)"
    return 1
  fi
}

bootout_job() {
  local svc="$1"
  local label
  label="$(label_for "$svc")"

  if ! is_loaded "$label"; then
    say "  ${C_DIM}$label not loaded${C_RESET}"
    return 0
  fi

  if launchctl bootout "$(gui_target)/$label" 2>/dev/null; then
    ok "$label booted out"
  else
    err "$label failed to bootout"
    return 1
  fi
}

# ── State (pause/resume) ──────────────────────────────────────────────────────
read_mode() {
  if [ -f "$STATE_FILE" ]; then
    grep -E '^mode=' "$STATE_FILE" 2>/dev/null | tail -1 | cut -d= -f2 || echo "running"
  else
    echo "running"
  fi
}

write_mode() {
  local mode="$1"
  mkdir -p "$STATE_DIR"
  printf 'mode=%s\nchanged_at=%s\n' "$mode" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$STATE_FILE"
}

# ── Health probes (used by `vera status`) ─────────────────────────────────────
probe_web() {
  curl -fsS --max-time 2 http://localhost:3000/api/dashboard/overview \
    -H "Authorization: Bearer ${NEXUS_HEALTH_TOKEN:-none}" >/dev/null 2>&1 && return 0
  # Even a 401 means the server is up and responding.
  local code
  code=$(curl -s --max-time 2 -o /dev/null -w '%{http_code}' http://localhost:3000/ 2>/dev/null || echo 000)
  [ "$code" != "000" ]
}
probe_arena()  { curl -fsS --max-time 2 http://localhost:3001/health     >/dev/null 2>&1; }
probe_ollama() { curl -fsS --max-time 2 http://localhost:11434/api/tags  >/dev/null 2>&1; }

probe_for() {
  case "$1" in
    web)         probe_web ;;
    arena)       probe_arena ;;
    ollama-check|ollama) probe_ollama ;;
    *) return 1 ;;
  esac
}

# ── Ollama lifecycle ──────────────────────────────────────────────────────────
# Boots the local Ollama daemon (the macOS app's background service or, if the
# app isn't installed, a bare `ollama serve`). Idempotent — does nothing if the
# daemon is already reachable. Fluid voice conversation in Lumen depends on
# this being up; otherwise voice turns fall through to Grok with cloud latency.
boot_ollama() {
  if curl -fsS --max-time 1 http://localhost:11434/api/tags >/dev/null 2>&1; then
    say "  ${C_DIM}ollama daemon already reachable${C_RESET}"
    return 0
  fi

  if [ -d "/Applications/Ollama.app" ]; then
    say "  ${C_DIM}booting Ollama.app…${C_RESET}"
    open -a Ollama -g >/dev/null 2>&1 || true
  elif command -v ollama >/dev/null 2>&1; then
    say "  ${C_DIM}starting ollama serve in background…${C_RESET}"
    nohup /usr/local/bin/ollama serve >/dev/null 2>&1 &
  else
    err "ollama not installed (no /Applications/Ollama.app, no /usr/local/bin/ollama)"
    say "    install: https://ollama.com/download"
    return 1
  fi

  # Wait up to 8 seconds for the daemon to come up
  for _ in 1 2 3 4 5 6 7 8; do
    sleep 1
    if curl -fsS --max-time 1 http://localhost:11434/api/tags >/dev/null 2>&1; then
      ok "ollama daemon up"
      return 0
    fi
  done
  warn "ollama didn't come up within 8s — check the Ollama app or run 'ollama serve' manually"
  return 1
}

# ── Subcommands ───────────────────────────────────────────────────────────────
cmd_up() {
  info "Bringing up Nexus services…"
  # Ollama first — Lumen's voice path prefers local brain when reachable
  boot_ollama || true
  local failures=0
  for svc in "${SERVICES[@]}"; do
    bootstrap_job "$svc" || failures=$((failures+1))
  done
  write_mode running
  if [ "$failures" -gt 0 ]; then
    warn "$failures service(s) failed to start. Run: vera status"
    return 1
  fi
  ok "Nexus is up."
}

cmd_down() {
  info "Taking down Nexus services…"
  for svc in "${SERVICES[@]}"; do
    bootout_job "$svc" || true
  done
  ok "Nexus is down."
}

cmd_pause() {
  info "Pausing Nexus (services will stay down across reboots)…"
  for svc in "${SERVICES[@]}"; do
    bootout_job "$svc" || true
  done
  write_mode paused
  warn "Lumen.app is still running. Quit it manually to fully pause. (P2)"
  ok "Nexus is paused. Run 'vera resume' to bring it back."
}

cmd_resume() {
  info "Resuming Nexus services…"
  cmd_up
}

# Soft-restart one or all services without a full down/up cycle. Useful after
# `git pull` or env changes where you just want the dev server to re-read.
kickstart_job() {
  local svc="$1"
  local label
  label="$(label_for "$svc")"

  if ! is_loaded "$label"; then
    err "$label not loaded (run: vera up)"
    return 1
  fi

  if launchctl kickstart -k "$(gui_target)/$label" 2>/dev/null; then
    ok "$label restarted"
  else
    err "$label failed to restart (check: vera logs $svc)"
    return 1
  fi
}

cmd_reload() {
  local target="${1:-}"
  if [ -n "$target" ]; then
    # Validate target is a known service.
    local found=0
    for svc in "${SERVICES[@]}"; do
      [ "$svc" = "$target" ] && found=1 && break
    done
    if [ "$found" -eq 0 ]; then
      err "Unknown service: $target"
      say "  Known: ${SERVICES[*]}"
      return 1
    fi
    info "Reloading ${target}…"
    kickstart_job "$target"
  else
    info "Reloading all Nexus services…"
    local failures=0
    for svc in "${SERVICES[@]}"; do
      kickstart_job "$svc" || failures=$((failures+1))
    done
    if [ "$failures" -gt 0 ]; then
      warn "$failures service(s) failed to reload"
      return 1
    fi
    ok "All services reloaded."
  fi
}

# Pad plain text to width, then wrap in color (so ANSI codes don't break alignment)
pad_color() {
  local text="$1" width="$2" color="${3:-}"
  local padded
  padded="$(printf '%-*s' "$width" "$text")"
  if [ -n "$color" ]; then
    printf '%s%s%s' "$color" "$padded" "$C_RESET"
  else
    printf '%s' "$padded"
  fi
}

cmd_status() {
  local mode header
  mode="$(read_mode)"
  if [ "$mode" = "paused" ]; then
    header="${C_YELLOW}PAUSED${C_RESET}"
  else
    header="${C_GREEN}RUNNING${C_RESET}"
  fi

  printf '%sVera%s v%s — Nexus is %s\n\n' "$C_BOLD" "$C_RESET" "$VERA_VERSION" "$header"
  printf '  %-16s %-10s %-10s %s\n'   "SERVICE" "LAUNCHD" "HEALTH" "NOTE"
  printf '  %-16s %-10s %-10s %s\n'   "-------" "-------" "------" "----"

  for svc in "${SERVICES[@]}"; do
    local label loaded health note
    label="$(label_for "$svc")"
    if is_loaded "$label"; then
      loaded="$(pad_color "loaded" 10 "$C_GREEN")"
    else
      loaded="$(pad_color "-"      10 "$C_DIM")"
    fi

    if probe_for "$svc"; then
      health="$(pad_color "ok"   10 "$C_GREEN")"
      note=""
    else
      health="$(pad_color "down" 10 "$C_RED")"
      note="${C_DIM}(no response)${C_RESET}"
    fi

    printf '  %-16s %s %s %s\n' "$svc" "$loaded" "$health" "$note"
  done

  printf '\n  %slogs:%s  %s/\n'   "$C_DIM" "$C_RESET" "$LOG_DIR"
  printf '  %sstate:%s %s\n'      "$C_DIM" "$C_RESET" "$STATE_FILE"
}

cmd_logs() {
  local svc="${1:-}"
  mkdir -p "$LOG_DIR"
  if [ -n "$svc" ]; then
    local file="$LOG_DIR/$svc.log"
    if [ ! -f "$file" ]; then
      err "No log file at $file"
      return 1
    fi
    info "Tailing $file (Ctrl-C to exit)…"
    tail -F "$file"
  else
    info "Tailing all Nexus logs (Ctrl-C to exit)…"
    local files=()
    for s in "${SERVICES[@]}"; do
      [ -f "$LOG_DIR/$s.log" ] && files+=("$LOG_DIR/$s.log")
    done
    if [ "${#files[@]}" -eq 0 ]; then
      warn "No log files yet at $LOG_DIR/"
      return 1
    fi
    tail -F "${files[@]}"
  fi
}

cmd_install() {
  info "Installing Vera…"

  mkdir -p "$LAUNCH_AGENTS" "$LOG_DIR" "$STATE_DIR"
  ok "Created $LOG_DIR"
  ok "Created $STATE_DIR"

  local installed=0 missing=()
  for svc in "${SERVICES[@]}"; do
    local src dst
    src="$(plist_src_for "$svc")"
    dst="$(plist_installed_for "$svc")"
    if [ ! -f "$src" ]; then
      missing+=("$svc")
      continue
    fi
    cp "$src" "$dst"
    ok "Installed $(basename "$dst")"
    installed=$((installed+1))
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    warn "Missing plist source(s): ${missing[*]}"
    warn "Will skip on 'vera up'. (Tracks D1-D3 of Operation Letsgo.)"
  fi

  # Symlink ~/bin/vera so it's on PATH.
  if [ ! -d "$HOME/bin" ]; then
    mkdir -p "$HOME/bin"
    ok "Created $HOME/bin"
  fi
  if [ ! -L "$HOME/bin/vera" ] || [ "$(readlink "$HOME/bin/vera")" != "$REPO_ROOT/scripts/vera" ]; then
    ln -sf "$REPO_ROOT/scripts/vera" "$HOME/bin/vera"
    ok "Symlinked $HOME/bin/vera → scripts/vera"
  else
    say "  ${C_DIM}$HOME/bin/vera symlink already current${C_RESET}"
  fi

  # Boot Ollama as part of first-run setup so the local brain is online from
  # the moment Vera is installed.
  info "Ensuring Ollama daemon is online…"
  boot_ollama || true

  # If state file said "paused" before install, respect it.
  local mode
  mode="$(read_mode)"
  if [ "$mode" = "paused" ]; then
    warn "State file says PAUSED — not auto-starting. Run 'vera resume' when ready."
  fi

  echo ""
  info "Manual step: add Lumen.app to Login Items"
  say "  System Settings → General → Login Items → '+' → /Applications/Lumen.app"
  echo ""
  info "Verify:"
  say "  which vera        # should print $HOME/bin/vera"
  say "  vera status       # see service state"
  say "  vera up           # bring up services"
}

cmd_uninstall() {
  info "Uninstalling Vera…"

  # Bootout any loaded jobs first.
  for svc in "${SERVICES[@]}"; do
    bootout_job "$svc" || true
  done

  for svc in "${SERVICES[@]}"; do
    local dst
    dst="$(plist_installed_for "$svc")"
    if [ -f "$dst" ]; then
      rm "$dst"
      ok "Removed $(basename "$dst")"
    fi
  done

  if [ -L "$HOME/bin/vera" ]; then
    rm "$HOME/bin/vera"
    ok "Removed $HOME/bin/vera symlink"
  fi

  warn "Logs at $LOG_DIR/ and state at $STATE_FILE were left in place."
  warn "Remove manually if desired."
}

# ── Doctor: full diagnostic ───────────────────────────────────────────────────
# Prints sectioned ✓/⚠️/✗ rows with actionable hints. Every check is best-effort
# and continues on failure — output is meant to be read top-to-bottom.

doc_ok()   { printf '  %s✓%s %s\n' "$C_GREEN" "$C_RESET" "$1"; }
doc_warn() { printf '  %s!%s %s\n  %s    %s%s\n' "$C_YELLOW" "$C_RESET" "$1" "$C_DIM" "$2" "$C_RESET"; }
doc_err()  { printf '  %s✗%s %s\n  %s    fix: %s%s\n' "$C_RED" "$C_RESET" "$1" "$C_DIM" "$2" "$C_RESET"; }
doc_section() { printf '\n%s%s%s\n' "$C_BOLD" "$1" "$C_RESET"; }

cmd_doctor() {
  printf '%sVera doctor%s — Nexus boot system diagnostic\n' "$C_BOLD" "$C_RESET"

  # ── Toolchain ──────────────────────────────────────────────────────────────
  doc_section "Toolchain"

  # NVM-resolved node + npm via with-node.sh
  if [ -x "$REPO_ROOT/scripts/launchd/with-node.sh" ]; then
    local node_path npm_path
    node_path="$("$REPO_ROOT/scripts/launchd/with-node.sh" /tmp /usr/bin/which node 2>/dev/null || true)"
    npm_path="$("$REPO_ROOT/scripts/launchd/with-node.sh" /tmp /usr/bin/which npm 2>/dev/null || true)"
    if [ -n "$node_path" ]; then
      doc_ok "node: $node_path ($("$node_path" --version 2>/dev/null))"
    else
      doc_err "node not resolvable via NVM" "ensure ~/.nvm/nvm.sh exists and 'default' alias is set"
    fi
    if [ -n "$npm_path" ]; then
      doc_ok "npm:  $npm_path"
    else
      doc_err "npm not resolvable via NVM" "nvm install --lts"
    fi
  else
    doc_err "with-node.sh missing" "restore from scripts/launchd/ or reinstall"
  fi

  # Ollama binary
  if command -v ollama >/dev/null 2>&1; then
    doc_ok "ollama: $(command -v ollama)"
  else
    doc_warn "ollama binary not on PATH" "brew install ollama (or install the Ollama macOS app)"
  fi

  # Xcode tooling for build-lumen.sh
  if command -v xcodebuild >/dev/null 2>&1; then
    doc_ok "xcodebuild present"
  else
    doc_warn "xcodebuild not on PATH" "needed for build-lumen.sh — install Xcode + run 'xcode-select -s /Applications/Xcode.app/Contents/Developer'"
  fi

  # ── Ports ──────────────────────────────────────────────────────────────────
  doc_section "Ports"
  for port in 3000 3001; do
    local svc_name
    case "$port" in 3000) svc_name="web" ;; 3001) svc_name="arena" ;; esac
    local who
    who="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $1" PID "$2}')"
    if [ -z "$who" ]; then
      doc_warn ":$port ($svc_name) — nothing listening" "vera up"
    else
      # Check if it's our launchd-managed process
      local label="com.nexus.$svc_name"
      if launchctl print "$(gui_target)/$label" >/dev/null 2>&1; then
        doc_ok ":$port ($svc_name) bound by $who [launchd-managed]"
      else
        doc_warn ":$port ($svc_name) bound by $who [stray, not launchd]" "kill the PID, then 'vera up'"
      fi
    fi
  done

  # ── launchd plists ─────────────────────────────────────────────────────────
  doc_section "launchd"
  for svc in "${SERVICES[@]}"; do
    local label installed src
    label="$(label_for "$svc")"
    installed="$(plist_installed_for "$svc")"
    src="$(plist_src_for "$svc")"

    if [ ! -f "$installed" ]; then
      doc_err "$label plist not installed" "vera install"
      continue
    fi
    if [ ! -f "$src" ]; then
      doc_warn "$label source plist missing in scripts/launchd/" "restore from git or reclone"
    fi
    if is_loaded "$label"; then
      doc_ok "$label loaded"
    else
      # ollama-check is a scheduled job; not loaded between runs is normal in some macOS versions.
      if [ "$svc" = "ollama-check" ]; then
        doc_warn "$label not loaded (will load at scheduled time 09:00)" "force-run: launchctl kickstart $(gui_target)/$label"
      else
        doc_err "$label not loaded" "vera up"
      fi
    fi
  done

  # ── Ollama runtime ─────────────────────────────────────────────────────────
  doc_section "Ollama"
  if curl -fsS --max-time 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
    doc_ok "daemon reachable at :11434"
    local installed expected_missing=()
    installed="$(curl -fsS http://localhost:11434/api/tags | grep -o '"name":"[^"]*"' | sed 's/"name":"//;s/"//' || true)"
    for model in "llama3.2:3b" "qwen2.5:3b" "llava:7b"; do
      if echo "$installed" | grep -Fxq "$model"; then
        doc_ok "model present: $model"
      else
        expected_missing+=("$model")
      fi
    done
    if [ "${#expected_missing[@]}" -gt 0 ]; then
      doc_warn "missing models: ${expected_missing[*]}" "ollama-check.sh will pull at 09:00, or run: ollama pull <name>"
    fi
  else
    doc_err "daemon unreachable at :11434" "open the Ollama macOS app, or run 'ollama serve'"
  fi

  # ── Disk space (Ollama models eat space) ───────────────────────────────────
  doc_section "Disk"
  if [ -d "$HOME/.ollama/models" ]; then
    local free_gb models_size
    free_gb="$(df -g "$HOME/.ollama" 2>/dev/null | awk 'NR==2 {print $4}')"
    models_size="$(du -sh "$HOME/.ollama/models" 2>/dev/null | awk '{print $1}')"
    if [ -n "$free_gb" ]; then
      if [ "$free_gb" -lt 5 ]; then
        doc_err "free disk: ${free_gb}GB (Ollama models: $models_size)" "free space — Ollama may evict models when tight"
      elif [ "$free_gb" -lt 20 ]; then
        doc_warn "free disk: ${free_gb}GB (Ollama models: $models_size)" "consider clearing space soon"
      else
        doc_ok "free disk: ${free_gb}GB (Ollama models: $models_size)"
      fi
    fi
  else
    doc_warn "~/.ollama/models not present yet" "first 'ollama pull' will create it"
  fi

  # ── Clock drift (Supabase JWTs silently 401 if too off) ────────────────────
  doc_section "Clock"
  if command -v sntp >/dev/null 2>&1; then
    local drift
    drift="$(sntp -t 2 time.apple.com 2>/dev/null | grep -oE '[+-][0-9]+\.[0-9]+ ' | head -1 | tr -d ' ')"
    if [ -n "$drift" ]; then
      # Strip sign for absolute comparison.
      local abs="${drift#-}"; abs="${abs#+}"
      local secs="${abs%.*}"
      if [ "$secs" -gt 60 ]; then
        doc_err "clock drift: ${drift}s vs Apple time" "System Settings → General → Date & Time → Set Automatically"
      elif [ "$secs" -gt 5 ]; then
        doc_warn "clock drift: ${drift}s" "may cause occasional Supabase 401s"
      else
        doc_ok "clock drift: ${drift}s (well within tolerance)"
      fi
    else
      doc_warn "could not measure clock drift" "sntp output unparseable; skip"
    fi
  else
    doc_warn "sntp not available" "skip clock check"
  fi

  # ── Filesystem layout ──────────────────────────────────────────────────────
  doc_section "Filesystem"
  for d in "$LOG_DIR" "$STATE_DIR" "$HOME/Library/Application Support/Lumen"; do
    if [ -d "$d" ] && [ -w "$d" ]; then
      doc_ok "$d"
    elif [ ! -d "$d" ]; then
      doc_warn "$d does not exist" "will be created on first use"
    else
      doc_err "$d not writable" "chmod / chown to fix"
    fi
  done

  # Lumen.app
  if [ -d "/Applications/Lumen.app" ]; then
    doc_ok "/Applications/Lumen.app installed"
  else
    doc_warn "/Applications/Lumen.app not installed" "./scripts/build-lumen.sh"
  fi

  # vera CLI on PATH
  if [ -L "$HOME/bin/vera" ]; then
    doc_ok "~/bin/vera symlink in place"
  else
    doc_warn "~/bin/vera not symlinked" "vera install"
  fi

  # ── Done ───────────────────────────────────────────────────────────────────
  printf '\n%sdoctor finished.%s See above for any ! or ✗ rows.\n' "$C_DIM" "$C_RESET"
}

cmd_help() {
  cat <<EOF
${C_BOLD}vera${C_RESET} — Nexus orchestrator (v$VERA_VERSION)

${C_BOLD}USAGE${C_RESET}
  vera <command> [args]

${C_BOLD}COMMANDS${C_RESET}
  up                 Bring up all Nexus services. Idempotent.
  down               Take down all Nexus services. Won't survive reboot.
  pause              Stop services and remember to stay paused across reboots.
  resume             Resume from paused state.
  reload [service]   Soft-restart one or all services (e.g. after a git pull).
  doctor             Run full diagnostic (toolchain, ports, plists, models, disk, clock).
  status             Show service state + health probes.
  logs [service]     Tail one or all service logs.
  install            One-time setup: install plists, create log dir, symlink ~/bin/vera.
  uninstall          Reverse of install.
  help               This message.
  --version          Print version.

${C_BOLD}SERVICES${C_RESET}
  web            nexus-web (Next.js) on :3000
  arena          arena (Express) on :3001
  ollama-check   daily probe + model refresh

${C_BOLD}EXAMPLES${C_RESET}
  vera up                # start everything
  vera status            # see what's running
  vera logs web          # tail nexus-web log
  vera pause             # before traveling
  vera resume            # back home

See also: ${C_DIM}mission/operation-letsgo.md${C_RESET}
EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${1:-help}" in
  up)         shift; cmd_up        "$@" ;;
  down)       shift; cmd_down      "$@" ;;
  pause)      shift; cmd_pause     "$@" ;;
  resume)     shift; cmd_resume    "$@" ;;
  reload)     shift; cmd_reload    "$@" ;;
  doctor)     shift; cmd_doctor    "$@" ;;
  status)     shift; cmd_status    "$@" ;;
  logs)       shift; cmd_logs      "$@" ;;
  install)    shift; cmd_install   "$@" ;;
  uninstall)  shift; cmd_uninstall "$@" ;;
  help|-h|--help) cmd_help ;;
  --version|-v)   echo "vera $VERA_VERSION" ;;
  *)
    err "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
